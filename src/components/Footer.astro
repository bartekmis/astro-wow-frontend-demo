---
import type { MenuItem } from "../lib/types";
import { rewriteWpUrl } from "../lib/wp";

interface Props {
  siteTitle: string;
  products: MenuItem[];
  company: MenuItem[];
}

const { siteTitle, products, company } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-ink border-t border-white/10">
  <div class="container py-20">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <a href="/" class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-primary text-white font-bold text-sm">W</span>
          <span class="font-semibold tracking-tight">{siteTitle}</span>
        </a>
        <div class="mt-6 flex gap-3">
          {(["YT", "IG", "X"] as const).map((tag) => (
            <a
              href="/"
              aria-label={tag}
              class="w-10 h-10 grid place-items-center rounded-full border border-white/10 hover:border-white/30 transition"
              target="_blank"
              rel="noopener noreferrer"
            >{tag}</a>
          ))}
        </div>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-sm uppercase tracking-[0.18em] text-grey mb-4">Produkty</h4>
        <ul class="space-y-3 text-white/85 list-none m-0 p-0">
          {products.map((item) => (
            <li>
              <a href={rewriteWpUrl(item.url)} target={item.target ?? undefined} class="hover:text-primary transition">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-sm uppercase tracking-[0.18em] text-grey mb-4">Firma</h4>
        <ul class="space-y-3 text-white/85 list-none m-0 p-0">
          {company.map((item) => (
            <li>
              <a href={rewriteWpUrl(item.url)} target={item.target ?? undefined} class="hover:text-primary transition">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-sm uppercase tracking-[0.18em] text-grey mb-4">Kontakt</h4>
        <ul class="space-y-3 text-white/85 list-none m-0 p-0">
          <li><a href="mailto:hello@webdevinsider.pl" class="hover:text-primary transition">hello@webdevinsider.pl</a></li>
          <li class="text-grey text-sm">Wymysłów, PL</li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row gap-4 items-center justify-between text-sm text-grey">
      <p>&copy; {year} {siteTitle}. Wszystkie prawa zastrzeżone.</p>
      <div class="flex gap-6">
        <a href="https://www.webdevinsider.pl/polityka-prywatnosci" class="hover:text-white transition">Polityka prywatności</a>
        <a href="https://www.webdevinsider.pl/regulamin" class="hover:text-white transition">Regulamin</a>
      </div>
    </div>
  </div>
</footer>
