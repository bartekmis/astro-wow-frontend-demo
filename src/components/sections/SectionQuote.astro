---
import type { Section, ResolvedImage } from "../../lib/types";
import { anchorId } from "../../lib/section-helpers";

interface Props { section: Section; }
const { section } = Astro.props;
const data = section.data;
const avatar = (data.avatar as ResolvedImage | string | undefined);
const avatarObj = (avatar && typeof avatar === "object") ? avatar : null;
---

<section id={anchorId(data)} class="section py-20">
  <div class="container max-w-3xl text-center">
    {data.eyebrow && (
      <p class="text-sm uppercase tracking-[0.18em] text-grey mb-6">{data.eyebrow}</p>
    )}
    {data.quote && (
      <blockquote class="text-2xl md:text-3xl font-medium leading-snug">
        &ldquo;{data.quote}&rdquo;
      </blockquote>
    )}
    <div class="mt-8 flex items-center justify-center gap-4">
      {avatarObj && (
        <img
          src={avatarObj.url}
          alt={avatarObj.alt}
          width={avatarObj.width}
          height={avatarObj.height}
          class="w-12 h-12 rounded-full object-cover"
          loading="lazy"
        />
      )}
      <div class="text-left">
        {data.author && <p class="font-semibold">{data.author}</p>}
        {data.role && <p class="text-grey text-sm">{data.role}</p>}
      </div>
    </div>
  </div>
</section>
