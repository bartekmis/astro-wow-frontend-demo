---
import type { Section } from "../../lib/types";
import { sectionWrapperClasses, containerClass, anchorId } from "../../lib/section-helpers";
import CwvChart from "./CwvChart.tsx";

interface Props { section: Section; }
const { section } = Astro.props;
const data = section.data;
const headline = (data.headline as string) || "";
---

<section id={anchorId(data) ?? "chart"} class={sectionWrapperClasses(data)}>
  <div class={containerClass(data)}>
    <div class="max-w-2xl mb-12">
      {data.eyebrow && (
        <p class="text-sm uppercase tracking-[0.18em] text-grey mb-4">{data.eyebrow}</p>
      )}
      {headline && <h2 class="text-3xl md:text-5xl font-bold mb-5 leading-tight" set:html={headline} />}
      {data.lead && <p class="text-grey text-lg leading-relaxed">{data.lead}</p>}
    </div>

    <CwvChart client:visible />
  </div>
</section>

<style is:global>
  .chart-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .chart-toggle:hover {
    border-color: rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.85);
  }
  .chart-toggle.is-active {
    background: color-mix(in srgb, var(--c) 12%, transparent);
    border-color: color-mix(in srgb, var(--c) 50%, transparent);
    color: #ffffff;
  }
  .chart-toggle .chart-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    transition: background 0.2s ease;
  }
  .chart-toggle.is-active .chart-dot {
    background: var(--c);
    box-shadow: 0 0 12px var(--c);
  }
  .chart-range {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
    cursor: pointer;
    transition: all 0.2s ease;
    background: transparent;
    border: 0;
  }
  .chart-range:hover { color: rgba(255, 255, 255, 0.85); }
  .chart-range.is-active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }
  .metric {
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.4);
    padding: 0.75rem 1rem;
    backdrop-filter: blur(12px);
  }
  .metric__label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-grey);
  }
  .metric__value {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1rem;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }
</style>
